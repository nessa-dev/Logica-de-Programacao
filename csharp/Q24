// Given the base and height of a rectangle, calculate its area and its perimeter.

using System;
class logic {
 static void Main() {

    int abase, height, area;
    Console.WriteLine("Provide the base of rectangle:");
    while(!int.TryParse(Console.ReadLine(), out abase)){
        Console.WriteLine("Invalid attempt. Please, inter a valid base:");
    }
    Console.WriteLine("Provide the height of rectangle:");
    while(!int.TryParse(Console.ReadLine(), out height)){
        Console.WriteLine("Invalid attempt. Please, inter a valid height:");
    }

    area = abase * height;

    Console.WriteLine("The area of rectangle is: " + area);
 }
}